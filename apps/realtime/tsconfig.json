{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "composite": true,
    "declarationMap": true,
    "baseUrl": "../../",
    "paths": {
      "@castaminofen/logger": ["packages/logger/src/index.ts"],
      "@castaminofen/config": ["packages/config/src/index.ts"],
      "@castaminofen/core": ["packages/core/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
