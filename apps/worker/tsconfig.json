{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "../..",
    "outDir": "dist",
    "composite": true,
    "declarationMap": true,
    "baseUrl": ".",
    "paths": {
      "@castaminofen/logger": ["../../packages/logger/src/index.ts"],
      "@castaminofen/logger/*": ["../../packages/logger/src/*"],
      "@castaminofen/types": ["../../packages/types/src/index.ts"],
      "@castaminofen/types/*": ["../../packages/types/src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "../../packages/logger/src/**/*.ts",
    "../../packages/types/src/**/*.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
